# ─── PlacementAI — Environment Variables Example ──────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit the real .env file to git.

# ── Shared ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GITHUB_TOKEN=your_github_personal_access_token_here

# ── Next.js Web App ─────────────────────────────────────────────────────────────
# SQLite path inside the container (mapped to db_data volume)
DATABASE_URL=file:/data/db/prod.db

# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Set to your public domain in production
NEXTAUTH_URL=http://localhost:3000

# Internal service URL — keep as-is when using docker-compose
AI_SERVICE_URL=http://ai-service:8000

# ── AI Service ─────────────────────────────────────────────────────────────────
# (same GEMINI_API_KEY and GITHUB_TOKEN above are injected into ai-service too)
